---
/**
 * Home — landing principal y hub de enlazado a los silos (CLAUDE.md §4).
 * Contenido editorial (servicios/sectores/productos/FAQ) desde collections;
 * copy de marketing (proceso/pilares/ventajas) desde src/config/home.ts.
 * Conversión: hero con 2 CTAs, proceso, diferenciadores, credenciales, FAQ y
 * formulario de cotización. JSON-LD FAQPage añadido al layout.
 * Animaciones: reveal "fade-up" con stagger en grids y hover-lift en tarjetas (§7/§8).
 */
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';
import Credenciales from '../components/Credenciales.astro';
import FAQ from '../components/FAQ.astro';
import CotizacionForm from '../components/CotizacionForm.astro';
import { site, whatsappUrl } from '../config/site';
import { pasos, pilares, ventajas } from '../config/home';
import { faqJsonLd } from '../lib/seo';
import { categorias as categoriasTienda } from '../lib/catalogo';
import heroBg from '../assets/brand/bg-feghadal.webp';

const porOrden = (a: { data: { orden: number } }, b: { data: { orden: number } }) =>
  a.data.orden - b.data.orden;

const servicios = (await getCollection('servicios')).sort(porOrden);
const sectores = (await getCollection('sectores')).sort(porOrden);
const faqs = (await getCollection('faq')).sort(porOrden);

// Mensajes segmentados del hero (cada uno enlaza a su silo).
const segmentos = [
  {
    icono: 'briefcase' as const,
    titulo: 'Empresas',
    texto: 'Limpieza y mantenimiento para tu operación.',
    href: '/sectores',
  },
  {
    icono: 'check-badge' as const,
    titulo: 'Sector público',
    texto: 'Proveedor formal con RNP para el Estado.',
    href: '/sectores/sector-publico',
  },
  {
    icono: 'cube' as const,
    titulo: 'Materiales',
    texto: 'Materiales y ferretería bajo un mismo proveedor.',
    href: '/tienda',
  },
];

const title = 'Servicios generales en el Perú: limpieza y mantenimiento';
const description =
  'FEGHADAL: empresa peruana de servicios generales. Limpieza integral, ' +
  'mantenimiento de inmuebles, instalaciones y acabados para ' +
  'empresas y entidades públicas.';

const jsonLd = [faqJsonLd(faqs.map((f) => f.data))];
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  {/* ===== Hero (CLAUDE.md §7) — imagen de fondo navy + overlay para legibilidad ===== */}
  <section class="relative overflow-hidden bg-brand-900 text-white">
    {/* Imagen de fondo (LCP). Decorativa (alt=""); el contraste lo asegura el overlay. */}
    <Image
      src={heroBg}
      alt=""
      aria-hidden="true"
      width={1280}
      height={720}
      loading="eager"
      fetchpriority="high"
      class="pointer-events-none absolute inset-0 h-full w-full object-cover"
    />
    {/* Overlay navy: garantiza contraste AA del texto blanco sobre cualquier zona. */}
    <div
      class="absolute inset-0 bg-gradient-to-r from-brand-900/90 via-brand-900/70 to-brand-900/40"
      aria-hidden="true"
    >
    </div>

    <div class="relative mx-auto max-w-[var(--spacing-content)] px-4 py-20 md:py-28">
      <p class="text-sm font-semibold uppercase tracking-wider text-brand-100">
        Servicios generales · Perú
      </p>
      <h1 class="mt-3 max-w-3xl text-4xl font-bold leading-tight md:text-5xl">
        Limpieza y mantenimiento para empresas e instituciones
      </h1>
      <p class="mt-5 max-w-2xl text-lg text-brand-100">
        {site.descripcion}
      </p>
      <div class="mt-8 flex flex-wrap gap-4">
        <a
          href="/contacto"
          class="rounded-md bg-accent-600 px-6 py-3 font-semibold text-white shadow-card hover:-translate-y-0.5 hover:bg-accent-700"
        >
          Solicita tu cotización
        </a>
        <a
          href="/servicios"
          class="rounded-md border border-brand-100 px-6 py-3 font-semibold text-white hover:bg-brand-600"
        >
          Ver servicios
        </a>
      </div>

      {/* Mensajes segmentados (glassmorphism sobre navy) */}
      <ul class="mt-12 grid gap-4 sm:grid-cols-3">
        {
          segmentos.map((seg) => (
            <li>
              <a
                href={seg.href}
                class="flex h-full items-start gap-3 rounded-xl border border-white/15 bg-white/5 p-4 backdrop-blur transition hover:-translate-y-1 hover:border-white/30 hover:bg-white/10"
              >
                <Icon name={seg.icono} class="h-6 w-6 shrink-0 text-accent-300" />
                <span>
                  <span class="block font-semibold text-white">{seg.titulo}</span>
                  <span class="mt-0.5 block text-sm text-brand-100">{seg.texto}</span>
                </span>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  {/* ===== Servicios ===== */}
  <section class="mx-auto max-w-[var(--spacing-content)] px-4 py-16">
    <div class="reveal">
      <h2 class="text-3xl font-bold text-brand-700">Nuestros servicios</h2>
      <p class="mt-2 max-w-2xl text-muted">
        Soluciones integrales de servicios generales bajo un mismo proveedor.
      </p>
    </div>
    <ul class="stagger mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        servicios.map((servicio) => (
          <li class="reveal hover-lift overflow-hidden rounded-xl border border-line bg-surface shadow-card">
            <a href={`/servicios/${servicio.id}`} class="group block">
              <Image
                src={servicio.data.imagen.src}
                alt={servicio.data.imagen.alt}
                width={600}
                height={338}
                class="aspect-video w-full object-cover"
              />
              <div class="p-5">
                <h3 class="text-lg font-semibold text-brand-700 group-hover:text-accent-600">
                  {servicio.data.titulo}
                </h3>
                <p class="mt-2 text-sm text-muted">{servicio.data.resumen}</p>
              </div>
            </a>
          </li>
        ))
      }
    </ul>
  </section>

  {/* ===== Cómo trabajamos (CLAUDE.md §1) ===== */}
  <section class="bg-surface-alt">
    <div class="mx-auto max-w-[var(--spacing-content)] px-4 py-16">
      <div class="reveal">
        <h2 class="text-3xl font-bold text-brand-700">Cómo trabajamos</h2>
        <p class="mt-2 max-w-2xl text-muted">
          Un proceso claro y transparente, del primer contacto a la entrega.
        </p>
      </div>
      <ol class="stagger mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {
          pasos.map((paso, i) => (
            <li class="reveal hover-lift relative rounded-xl border border-line bg-surface p-6 shadow-card">
              <span
                class="absolute right-4 top-4 text-3xl font-bold text-brand-100"
                aria-hidden="true"
              >
                {i + 1}
              </span>
              <Icon name={paso.icono} class="h-9 w-9 text-accent-600" />
              <h3 class="mt-4 text-lg font-semibold text-brand-700">{paso.titulo}</h3>
              <p class="mt-2 text-sm text-muted">{paso.descripcion}</p>
            </li>
          ))
        }
      </ol>
      <div class="reveal mt-8">
        <a
          href="/contacto"
          class="inline-block rounded-md bg-accent-600 px-6 py-3 font-semibold text-white shadow-card hover:-translate-y-0.5 hover:bg-accent-700"
        >
          Empieza tu cotización
        </a>
      </div>
    </div>
  </section>

  {/* ===== Por qué FEGHADAL (CLAUDE.md §2) ===== */}
  <section class="mx-auto max-w-[var(--spacing-content)] px-4 py-16">
    <div class="reveal">
      <h2 class="text-3xl font-bold text-brand-700">Por qué FEGHADAL</h2>
      <p class="mt-2 max-w-2xl text-muted">
        Diferenciadores reales que aportan tranquilidad a tu empresa o entidad.
      </p>
    </div>
    <ul class="stagger mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {
        pilares.map((pilar) => (
          <li class="reveal hover-lift rounded-xl border border-line bg-surface p-6 shadow-card">
            <Icon name={pilar.icono} class="h-9 w-9 text-accent-600" />
            <h3 class="mt-4 text-lg font-semibold text-brand-700">{pilar.titulo}</h3>
            <p class="mt-2 text-sm text-muted">{pilar.descripcion}</p>
          </li>
        ))
      }
    </ul>
  </section>

  {/* ===== Sectores ===== */}
  <section class="bg-surface-alt">
    <div class="mx-auto max-w-[var(--spacing-content)] px-4 py-16">
      <div class="reveal">
        <h2 class="text-3xl font-bold text-brand-700">Sectores que atendemos</h2>
        <p class="mt-2 max-w-2xl text-muted">
          Adaptamos cada servicio a las exigencias específicas de tu sector.
        </p>
      </div>
      <ul class="stagger mt-8 grid gap-6 sm:grid-cols-2">
        {
          sectores.map((sector) => (
            <li class="reveal hover-lift overflow-hidden rounded-xl border border-line bg-surface shadow-card">
              <a href={`/sectores/${sector.id}`} class="group block">
                <Image
                  src={sector.data.imagen.src}
                  alt={sector.data.imagen.alt}
                  width={600}
                  height={338}
                  class="aspect-video w-full object-cover"
                />
                <div class="p-6">
                  <h3 class="text-lg font-semibold text-brand-700 group-hover:text-accent-600">
                    {sector.data.titulo}
                  </h3>
                  <p class="mt-2 text-sm text-muted">{sector.data.resumen}</p>
                </div>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  {/* ===== Ventajas de tercerizar (CLAUDE.md §3) ===== */}
  <section class="mx-auto max-w-[var(--spacing-content)] px-4 py-16">
    <div class="reveal">
      <h2 class="text-3xl font-bold text-brand-700">Ventajas de tercerizar con FEGHADAL</h2>
      <p class="mt-2 max-w-2xl text-muted">
        Externalizar tus servicios generales libera a tu equipo y ordena tus costos.
      </p>
    </div>
    <ul class="stagger mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        ventajas.map((ventaja) => (
          <li class="reveal hover-lift flex gap-4 rounded-xl border border-line bg-surface p-6 shadow-card">
            <Icon name={ventaja.icono} class="h-8 w-8 shrink-0 text-accent-600" />
            <div>
              <h3 class="text-lg font-semibold text-brand-700">{ventaja.titulo}</h3>
              <p class="mt-2 text-sm text-muted">{ventaja.descripcion}</p>
            </div>
          </li>
        ))
      }
    </ul>
    <div class="reveal mt-8">
      <a
        href="/contacto"
        class="inline-block rounded-md bg-accent-600 px-6 py-3 font-semibold text-white shadow-card hover:-translate-y-0.5 hover:bg-accent-700"
      >
        Conversemos sobre tu necesidad
      </a>
    </div>
  </section>

  {/* ===== Productos ===== */}
  <section class="bg-surface-alt">
    <div class="mx-auto max-w-[var(--spacing-content)] px-4 py-16">
      <div class="reveal flex flex-wrap items-end justify-between gap-4">
        <div>
          <h2 class="text-3xl font-bold text-brand-700">Tienda de materiales y ferretería</h2>
          <p class="mt-2 max-w-2xl text-muted">
            Comercializamos materiales y ferretería. Explora el catálogo por categorías,
            arma tu pedido y cotiza al instante por WhatsApp.
          </p>
        </div>
        <a
          href="/tienda"
          class="text-sm font-semibold text-accent-600 underline-offset-2 hover:text-accent-700 hover:underline"
        >
          Ver toda la tienda →
        </a>
      </div>
      <ul class="stagger mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {
          categoriasTienda.map((c) => (
            <li class="reveal">
              <a
                href={`/tienda/${c.slug}`}
                class="hover-lift flex items-center justify-between rounded-xl border border-line bg-surface p-5 shadow-card"
              >
                <span class="font-semibold text-brand-700">{c.nombre}</span>
                <span class="rounded-full bg-accent-50 px-2.5 py-1 text-xs font-medium text-accent-700">
                  {c.total}
                </span>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  {/* ===== Credenciales y cumplimiento (CLAUDE.md §4) ===== */}
  <section class="reveal mx-auto max-w-[var(--spacing-content)] px-4 py-16">
    <Credenciales destacado />
  </section>

  {/* ===== FAQ (CLAUDE.md §5, JSON-LD FAQPage) ===== */}
  <section class="bg-surface-alt">
    <div class="reveal mx-auto max-w-[var(--spacing-content)] px-4 py-16">
      <FAQ items={faqs} />
    </div>
  </section>

  {/* ===== Formulario de cotización (CLAUDE.md §6) ===== */}
  <section class="reveal mx-auto max-w-[var(--spacing-content)] px-4 py-16">
    <div class="grid gap-12 lg:grid-cols-[2fr_1fr]">
      <div>
        <h2 class="text-3xl font-bold text-brand-700">Solicita tu cotización</h2>
        <p class="mt-2 max-w-2xl text-muted">
          Cuéntanos qué necesitas y te enviamos una propuesta a medida. Atendemos al
          sector privado y a entidades públicas.
        </p>
        <div class="mt-8">
          <CotizacionForm />
        </div>
      </div>
      <aside class="space-y-6">
        <section class="rounded-xl border border-line bg-surface-alt p-6">
          <h3 class="text-lg font-semibold text-brand-700">¿Prefieres escribirnos?</h3>
          <p class="mt-2 text-sm text-muted">
            Estamos disponibles por WhatsApp y teléfono en horario de atención.
          </p>
          <a
            href={whatsappUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="mt-4 inline-block rounded-md bg-whatsapp px-5 py-3 font-semibold text-white hover:bg-whatsapp-700"
          >
            Escríbenos por WhatsApp
          </a>
          <dl class="mt-6 space-y-3 text-sm">
            <div>
              <dt class="text-xs uppercase tracking-wide text-muted">Teléfono</dt>
              <dd>
                <a
                  href={`tel:${site.telefono.replace(/\s+/g, '')}`}
                  class="font-medium text-accent-600 underline-offset-2 hover:underline"
                >
                  {site.telefonoDisplay}
                </a>
              </dd>
            </div>
            <div>
              <dt class="text-xs uppercase tracking-wide text-muted">Correo</dt>
              <dd>
                <a
                  href={`mailto:${site.email}`}
                  class="font-medium text-accent-600 underline-offset-2 hover:underline"
                >
                  {site.email}
                </a>
              </dd>
            </div>
          </dl>
        </section>
      </aside>
    </div>
  </section>
</BaseLayout>
