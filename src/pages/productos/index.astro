---
/**
 * Índice del silo PRODUCTOS (CLAUDE.md §4) — venta de materiales y ferretería.
 */
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { breadcrumbJsonLd, type Breadcrumb } from '../../lib/seo';

const productos = (await getCollection('productos')).sort(
  (a, b) => a.data.orden - b.data.orden,
);

const migas: Breadcrumb[] = [
  { nombre: 'Inicio', href: '/' },
  { nombre: 'Productos', href: '/productos' },
];

const title = 'Productos: materiales de construcción, ferretería y más';
const description =
  'Venta de materiales de construcción, ferretería, pinturas, materiales de ' +
  'gasfitería y vidrios en el Perú, con asesoría y abastecimiento para empresas y obras.';
---

<BaseLayout
  title={title}
  description={description}
  jsonLd={[breadcrumbJsonLd(migas, Astro.site!)]}
>
  <div class="mx-auto max-w-[var(--spacing-content)] px-4 py-10">
    <Breadcrumbs items={migas} />
    <div class="reveal">
      <h1 class="mt-6 text-4xl font-bold text-brand-700">Productos y materiales</h1>
      <p class="mt-3 max-w-2xl text-lg text-muted">
        Comercializamos materiales y ferretería para obras, empresas y mantenimiento.
        Combinados con nuestros servicios, ofrecemos una solución llave en mano.
      </p>
    </div>

    {/* Acceso a la tienda (catálogo con pedido por WhatsApp) */}
    <div class="reveal mt-8 flex flex-wrap items-center justify-between gap-4 rounded-xl border border-accent-200 bg-accent-50 p-6">
      <div>
        <h2 class="text-xl font-bold text-brand-700">Compra en nuestra tienda</h2>
        <p class="mt-1 text-muted">
          Explora el catálogo por categorías, arma tu pedido y cotiza al instante por WhatsApp.
        </p>
      </div>
      <a
        href="/tienda"
        class="inline-block shrink-0 rounded-md bg-accent-600 px-6 py-3 font-semibold text-white shadow-card transition hover:-translate-y-0.5 hover:bg-accent-700"
      >
        Ver catálogo →
      </a>
    </div>

    <ul class="stagger mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        productos.map((producto) => (
          <li class="reveal hover-lift overflow-hidden rounded-xl border border-line bg-surface shadow-card">
            <a href={`/productos/${producto.id}`} class="group block">
              <Image
                src={producto.data.imagen.src}
                alt={producto.data.imagen.alt}
                width={600}
                height={338}
                class="aspect-video w-full object-cover"
              />
              <div class="p-5">
                <h2 class="text-lg font-semibold text-brand-700 group-hover:text-accent-600">
                  {producto.data.titulo}
                </h2>
                <p class="mt-2 text-sm text-muted">{producto.data.resumen}</p>
              </div>
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</BaseLayout>
