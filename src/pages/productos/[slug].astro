---
/**
 * Pillar page de producto (CLAUDE.md §4, §5).
 * Render desde la collection `productos`. Muestra categorías y, mediante enlazado
 * cruzado inverso, los servicios de FEGHADAL que usan estos materiales.
 * JSON-LD OfferCatalog (productJsonLd) + BreadcrumbList.
 */
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import CTACotizacion from '../../components/CTACotizacion.astro';
import {
  productJsonLd,
  breadcrumbJsonLd,
  type Breadcrumb,
} from '../../lib/seo';

export async function getStaticPaths() {
  const productos = await getCollection('productos');
  return productos.map((producto) => ({
    params: { slug: producto.id },
    props: { producto },
  }));
}

const { producto } = Astro.props;
const { data } = producto;
const { Content } = await render(producto);

// Enlazado cruzado inverso: servicios que utilizan este material.
const serviciosQueLoUsan = (await getCollection('servicios')).filter((s) =>
  s.data.productosRelacionados.some((ref) => ref.id === producto.id),
);

const pageUrl = new URL(Astro.url.pathname, Astro.site).toString();

const migas: Breadcrumb[] = [
  { nombre: 'Inicio', href: '/' },
  { nombre: 'Productos', href: '/productos' },
  { nombre: data.titulo, href: `/productos/${producto.id}` },
];

const jsonLd = [
  productJsonLd(data, pageUrl, Astro.site!),
  breadcrumbJsonLd(migas, Astro.site!),
];

const tituloIncluyeKeyword = data.titulo
  .toLowerCase()
  .includes(data.keywordPrimaria.toLowerCase());
const seoTitle = tituloIncluyeKeyword
  ? `${data.titulo} en el Perú`
  : `${data.titulo}: ${data.keywordPrimaria}`;
---

<BaseLayout
  title={seoTitle}
  description={data.descripcionSEO}
  image={data.imagen.src.src}
  jsonLd={jsonLd}
>
  <div class="mx-auto max-w-[var(--spacing-content)] px-4 py-10">
    <Breadcrumbs items={migas} />

    <header class="mt-6 grid gap-8 lg:grid-cols-2 lg:items-center">
      <div>
        <h1 class="text-4xl font-bold leading-tight text-ink">{data.titulo}</h1>
        <p class="mt-4 text-lg text-muted">{data.resumen}</p>
      </div>
      <Image
        src={data.imagen.src}
        alt={data.imagen.alt}
        width={960}
        height={540}
        loading="eager"
        class="aspect-video w-full rounded-lg object-cover"
      />
    </header>

    <div class="mt-12 grid gap-12 lg:grid-cols-[2fr_1fr]">
      <article
        class="max-w-none [&_h2]:mt-8 [&_h2]:text-2xl [&_h2]:font-bold [&_h2]:text-ink [&_h3]:mt-6 [&_h3]:text-xl [&_h3]:font-semibold [&_h3]:text-ink [&_li]:mt-1 [&_p]:mt-4 [&_p]:leading-relaxed [&_p]:text-ink [&_ul]:mt-4 [&_ul]:list-disc [&_ul]:pl-6"
      >
        <Content />
      </article>

      <aside class="space-y-8">
        <section class="rounded-lg border border-line bg-surface-alt p-6">
          <h2 class="text-lg font-semibold text-ink">Categorías</h2>
          <ul class="mt-4 space-y-2">
            {
              data.categorias.map((cat) => (
                <li class="flex gap-2 text-sm text-ink">
                  <span aria-hidden="true" class="text-accent-600">
                    ✓
                  </span>
                  <span>{cat}</span>
                </li>
              ))
            }
          </ul>
        </section>

        {
          serviciosQueLoUsan.length > 0 && (
            <nav
              aria-label="Servicios que usan estos materiales"
              class="rounded-lg border border-line p-6"
            >
              <h2 class="text-lg font-semibold text-ink">
                Servicios que los usan
              </h2>
              <ul class="mt-4 space-y-2">
                {serviciosQueLoUsan.map((servicio) => (
                  <li>
                    <a
                      href={`/servicios/${servicio.id}`}
                      class="text-sm text-accent-600 underline-offset-2 hover:text-accent-700 hover:underline"
                    >
                      {servicio.data.titulo}
                    </a>
                  </li>
                ))}
              </ul>
            </nav>
          )
        }
      </aside>
    </div>

    <CTACotizacion
      titulo={`¿Buscas ${data.keywordPrimaria}?`}
      texto="Cotiza materiales y, si lo necesitas, combínalos con nuestros servicios para una solución llave en mano. Atendemos a empresas y obras en todo el Perú."
    />
  </div>
</BaseLayout>
