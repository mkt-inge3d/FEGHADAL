---
/**
 * Índice de la TIENDA (catálogo de materiales y ferretería).
 * Lista categorías y una muestra de productos; el carrito (isla) arma el pedido
 * y lo envía por WhatsApp. Datos desde src/lib/catalogo (src/data/catalogo.json).
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import ProductoCard from '../../components/ProductoCard.astro';
import Carrito from '../../components/Carrito.astro';
import { breadcrumbJsonLd, type Breadcrumb } from '../../lib/seo';
import { categorias, productos } from '../../lib/catalogo';

const migas: Breadcrumb[] = [
  { nombre: 'Inicio', href: '/' },
  { nombre: 'Tienda', href: '/tienda' },
];

const destacados = productos.slice(0, 12);

const title = 'Tienda de materiales de construcción y ferretería';
const description =
  'Catálogo de materiales de construcción, ferretería, cerámicos, pinturas, baños e ' +
  'iluminación. Arma tu pedido y cotiza al instante por WhatsApp con FEGHADAL.';
---

<BaseLayout
  title={title}
  description={description}
  jsonLd={[breadcrumbJsonLd(migas, Astro.site!)]}
>
  <div class="mx-auto max-w-[var(--spacing-content)] px-4 py-10">
    <Breadcrumbs items={migas} />
    <div class="reveal mt-6">
      <h1 class="text-4xl font-bold text-brand-700">Tienda de materiales y ferretería</h1>
      <p class="mt-3 max-w-2xl text-lg text-muted">
        Arma tu pedido con los productos que necesitas y envíalo por WhatsApp. Te
        confirmamos disponibilidad y precio al instante.
      </p>
    </div>

    {/* Categorías */}
    <h2 class="mt-10 text-2xl font-bold text-brand-700">Categorías</h2>
    <ul class="stagger mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        categorias.map((c) => (
          <li class="reveal">
            <a
              href={`/tienda/${c.slug}`}
              class="hover-lift flex items-center justify-between rounded-xl border border-line bg-surface p-5 shadow-card"
            >
              <span class="font-semibold text-brand-700">{c.nombre}</span>
              <span class="rounded-full bg-accent-50 px-2.5 py-1 text-xs font-medium text-accent-700">
                {c.total}
              </span>
            </a>
          </li>
        ))
      }
    </ul>

    {/* Muestra de productos */}
    <div class="reveal mt-12 flex flex-wrap items-end justify-between gap-4">
      <h2 class="text-2xl font-bold text-brand-700">Productos destacados</h2>
    </div>
    <ul class="stagger mt-6 grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-4">
      {
        destacados.map((p) => (
          <li class="reveal">
            <ProductoCard producto={p} />
          </li>
        ))
      }
    </ul>

    <p class="mt-8 text-sm text-muted">
      ¿No encuentras lo que buscas? Trabajamos con más de 4000 productos.{' '}
      <a href="/contacto" class="font-medium text-accent-600 underline-offset-2 hover:underline">
        Escríbenos
      </a>{' '}
      y lo conseguimos.
    </p>
  </div>

  <Carrito />
</BaseLayout>
