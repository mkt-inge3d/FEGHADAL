---
/**
 * Pillar page de servicio (CLAUDE.md §4, §5).
 * Render desde la collection `servicios`. Genera:
 *  - <h1> con keyword primaria, contenido Markdown, alcance y beneficios.
 *  - Enlazado interno: sectores donde aplica, cruces específicos, hermanas del silo
 *    y bloque "solución llave en mano" (productos relacionados).
 *  - JSON-LD Service + BreadcrumbList (desde frontmatter, vía src/lib/seo).
 */
import { getCollection, getEntry, render } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import SolucionLlaveEnMano from '../../components/SolucionLlaveEnMano.astro';
import CTACotizacion from '../../components/CTACotizacion.astro';
import {
  serviceJsonLd,
  breadcrumbJsonLd,
  type Breadcrumb,
} from '../../lib/seo';

export async function getStaticPaths() {
  const servicios = await getCollection('servicios');
  return servicios.map((servicio) => ({
    params: { slug: servicio.id },
    props: { servicio },
  }));
}

const { servicio } = Astro.props;
const { data } = servicio;
const { Content } = await render(servicio);

// Sectores donde aplica este servicio (enlazado de silos).
const sectoresRelacionados = (
  await Promise.all(data.sectoresRelacionados.map((ref) => getEntry(ref)))
).filter((s) => s !== undefined);

// Productos que usa el servicio (solución llave en mano).
const productosRelacionados = (
  await Promise.all(data.productosRelacionados.map((ref) => getEntry(ref)))
).filter((p) => p !== undefined);

// Cruces específicos de este servicio (long-tail).
const cruces = (await getCollection('cruces')).filter(
  (c) => c.data.servicio.id === servicio.id,
);

// Hermanas del silo (otros servicios), ordenadas.
const hermanas = (await getCollection('servicios'))
  .filter((s) => s.id !== servicio.id)
  .sort((a, b) => a.data.orden - b.data.orden);

const pageUrl = new URL(Astro.url.pathname, Astro.site).toString();

const migas: Breadcrumb[] = [
  { nombre: 'Inicio', href: '/' },
  { nombre: 'Servicios', href: '/servicios' },
  { nombre: data.titulo, href: `/servicios/${servicio.id}` },
];

const jsonLd = [
  serviceJsonLd(data, pageUrl, Astro.site!),
  breadcrumbJsonLd(migas, Astro.site!),
];

// Evita duplicar la keyword si el título ya la contiene.
const tituloIncluyeKeyword = data.titulo
  .toLowerCase()
  .includes(data.keywordPrimaria.toLowerCase());
const seoTitle = tituloIncluyeKeyword
  ? `${data.titulo} para empresas en el Perú`
  : `${data.titulo}: ${data.keywordPrimaria}`;
---

<BaseLayout
  title={seoTitle}
  description={data.descripcionSEO}
  image={data.imagen.src.src}
  jsonLd={jsonLd}
>
  <div class="mx-auto max-w-[var(--spacing-content)] px-4 py-10">
    <Breadcrumbs items={migas} />

    {/* Encabezado */}
    <header class="mt-6 grid gap-8 lg:grid-cols-2 lg:items-center">
      <div>
        <h1 class="text-4xl font-bold leading-tight text-ink">{data.titulo}</h1>
        <p class="mt-4 text-lg text-muted">{data.resumen}</p>
      </div>
      <Image
        src={data.imagen.src}
        alt={data.imagen.alt}
        width={960}
        height={540}
        loading="eager"
        class="aspect-video w-full rounded-lg object-cover"
      />
    </header>

    <div class="mt-12 grid gap-12 lg:grid-cols-[2fr_1fr]">
      {/* Contenido principal */}
      <article
        class="prose-feghadal max-w-none [&_h2]:mt-8 [&_h2]:text-2xl [&_h2]:font-bold [&_h2]:text-ink [&_h3]:mt-6 [&_h3]:text-xl [&_h3]:font-semibold [&_h3]:text-ink [&_li]:mt-1 [&_p]:mt-4 [&_p]:leading-relaxed [&_p]:text-ink [&_ul]:mt-4 [&_ul]:list-disc [&_ul]:pl-6"
      >
        <Content />

        {
          data.beneficios.length > 0 && (
            <section>
              <h2>Beneficios</h2>
              <ul>
                {data.beneficios.map((b) => (
                  <li>{b}</li>
                ))}
              </ul>
            </section>
          )
        }
      </article>

      {/* Aside: alcance + enlazado interno */}
      <aside class="space-y-8">
        <section class="rounded-lg border border-line bg-surface-alt p-6">
          <h2 class="text-lg font-semibold text-ink">Alcance del servicio</h2>
          <ul class="mt-4 space-y-2">
            {
              data.alcance.map((item) => (
                <li class="flex gap-2 text-sm text-ink">
                  <span aria-hidden="true" class="text-accent-600">
                    ✓
                  </span>
                  <span>{item}</span>
                </li>
              ))
            }
          </ul>
        </section>

        {
          sectoresRelacionados.length > 0 && (
            <nav
              aria-label="Sectores donde aplicamos este servicio"
              class="rounded-lg border border-line p-6"
            >
              <h2 class="text-lg font-semibold text-ink">
                Sectores donde aplicamos este servicio
              </h2>
              <ul class="mt-4 space-y-2">
                {sectoresRelacionados.map((sector) => (
                  <li>
                    <a
                      href={`/sectores/${sector.id}`}
                      class="text-sm text-brand-700 underline-offset-2 hover:underline"
                    >
                      {sector.data.titulo}
                    </a>
                  </li>
                ))}
              </ul>
            </nav>
          )
        }
      </aside>
    </div>

    {/* Cruces específicos (long-tail) */}
    {
      cruces.length > 0 && (
        <section class="mt-12">
          <h2 class="text-2xl font-bold text-ink">
            Este servicio por sector
          </h2>
          <ul class="mt-6 grid gap-4 sm:grid-cols-2">
            {cruces.map((cruce) => (
              <li>
                <a
                  href={`/servicios/${cruce.data.servicio.id}/${cruce.data.sector.id}`}
                  class="group flex h-full flex-col rounded-lg border border-line bg-surface p-5 hover:border-brand-300"
                >
                  <span class="font-semibold text-brand-700 group-hover:underline">
                    {cruce.data.titulo}
                  </span>
                  <span class="mt-1 text-sm text-muted">{cruce.data.resumen}</span>
                </a>
              </li>
            ))}
          </ul>
        </section>
      )
    }

    {/* Solución llave en mano (servicio + materiales) */}
    <SolucionLlaveEnMano productos={productosRelacionados} />

    {/* Otros servicios (hermanas del silo) */}
    <nav aria-label="Otros servicios" class="mt-12">
      <h2 class="text-2xl font-bold text-ink">Otros servicios</h2>
      <ul class="mt-6 flex flex-wrap gap-3">
        {
          hermanas.map((h) => (
            <li>
              <a
                href={`/servicios/${h.id}`}
                class="inline-block rounded-full border border-line px-4 py-2 text-sm text-brand-700 hover:border-brand-300 hover:bg-surface-alt"
              >
                {h.data.titulo}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <CTACotizacion titulo={`¿Necesitas ${data.keywordPrimaria}?`} />
  </div>
</BaseLayout>
