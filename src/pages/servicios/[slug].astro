---
/**
 * Pillar page de servicio (CLAUDE.md §4, §5).
 * Render desde la collection `servicios`. Genera:
 *  - <h1> con keyword primaria, contenido Markdown, alcance.
 *  - Enlazado interno a sectores relacionados (silos).
 *  - JSON-LD Service + BreadcrumbList (desde frontmatter, vía src/lib/seo).
 *  - Breadcrumbs visibles + meta/canonical/OG vía <SEO> en el layout.
 */
import { getCollection, getEntry, render } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import {
  serviceJsonLd,
  breadcrumbJsonLd,
  type Breadcrumb,
} from '../../lib/seo';

export async function getStaticPaths() {
  const servicios = await getCollection('servicios');
  return servicios.map((servicio) => ({
    params: { slug: servicio.id },
    props: { servicio },
  }));
}

const { servicio } = Astro.props;
const { data } = servicio;
const { Content } = await render(servicio);

// Resolver sectores relacionados para enlazado interno (silos SEO).
const sectoresRelacionados = (
  await Promise.all(
    data.sectoresRelacionados.map((ref) => getEntry(ref)),
  )
).filter((s) => s !== undefined);

const pageUrl = new URL(Astro.url.pathname, Astro.site).toString();

const migas: Breadcrumb[] = [
  { nombre: 'Inicio', href: '/' },
  { nombre: 'Servicios', href: '/servicios' },
  { nombre: data.titulo, href: `/servicios/${servicio.id}` },
];

const jsonLd = [
  serviceJsonLd(data, pageUrl, Astro.site!),
  breadcrumbJsonLd(migas, Astro.site!),
];

// Evita duplicar la keyword si el título ya la contiene.
const tituloIncluyeKeyword = data.titulo
  .toLowerCase()
  .includes(data.keywordPrimaria.toLowerCase());
const seoTitle = tituloIncluyeKeyword
  ? `${data.titulo} para empresas en el Perú`
  : `${data.titulo}: ${data.keywordPrimaria}`;
---

<BaseLayout
  title={seoTitle}
  description={data.descripcionSEO}
  image={data.imagen.src.src}
  jsonLd={jsonLd}
>
  <div class="mx-auto max-w-[var(--spacing-content)] px-4 py-10">
    <Breadcrumbs items={migas} />

    {/* Encabezado */}
    <header class="mt-6 grid gap-8 lg:grid-cols-2 lg:items-center">
      <div>
        <h1 class="text-4xl font-bold leading-tight text-ink">{data.titulo}</h1>
        <p class="mt-4 text-lg text-muted">{data.resumen}</p>
      </div>
      <Image
        src={data.imagen.src}
        alt={data.imagen.alt}
        width={960}
        height={540}
        loading="eager"
        class="aspect-video w-full rounded-lg object-cover"
      />
    </header>

    <div class="mt-12 grid gap-12 lg:grid-cols-[2fr_1fr]">
      {/* Contenido principal */}
      <article
        class="prose-feghadal max-w-none [&_h2]:mt-8 [&_h2]:text-2xl [&_h2]:font-bold [&_h2]:text-ink [&_h3]:mt-6 [&_h3]:text-xl [&_h3]:font-semibold [&_h3]:text-ink [&_li]:mt-1 [&_p]:mt-4 [&_p]:leading-relaxed [&_p]:text-ink [&_ul]:mt-4 [&_ul]:list-disc [&_ul]:pl-6"
      >
        <Content />
      </article>

      {/* Aside: alcance + enlazado interno */}
      <aside class="space-y-8">
        <section class="rounded-lg border border-line bg-surface-alt p-6">
          <h2 class="text-lg font-semibold text-ink">Alcance del servicio</h2>
          <ul class="mt-4 space-y-2">
            {
              data.alcance.map((item) => (
                <li class="flex gap-2 text-sm text-ink">
                  <span aria-hidden="true" class="text-accent-600">
                    ✓
                  </span>
                  <span>{item}</span>
                </li>
              ))
            }
          </ul>
        </section>

        {
          sectoresRelacionados.length > 0 && (
            <nav
              aria-label="Sectores relacionados"
              class="rounded-lg border border-line p-6"
            >
              <h2 class="text-lg font-semibold text-ink">
                Sectores relacionados
              </h2>
              <ul class="mt-4 space-y-2">
                {sectoresRelacionados.map((sector) => (
                  <li>
                    <a
                      href={`/sectores/${sector.id}`}
                      class="text-sm text-brand-700 underline-offset-2 hover:underline"
                    >
                      {sector.data.titulo}
                    </a>
                  </li>
                ))}
              </ul>
            </nav>
          )
        }
      </aside>
    </div>

    {/* CTA */}
    <section class="mt-16 rounded-lg bg-brand-700 p-8 text-white md:p-12">
      <h2 class="text-2xl font-bold">¿Necesitas {data.keywordPrimaria}?</h2>
      <p class="mt-3 max-w-2xl text-brand-100">
        Solicita una cotización a medida. Atendemos al sector privado y a entidades
        públicas en todo el Perú.
      </p>
      <a
        href="/nosotros"
        class="mt-6 inline-block rounded-md bg-accent-500 px-6 py-3 font-semibold text-white hover:bg-accent-600"
      >
        Conoce a FEGHADAL
      </a>
    </section>
  </div>
</BaseLayout>
