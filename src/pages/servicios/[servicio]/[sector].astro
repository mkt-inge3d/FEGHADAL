---
/**
 * Página de cruce servicio×sector (CLAUDE.md §4).
 * Se genera SOLO desde la collection `cruces` → únicamente los cruces con contenido
 * real y único (anti doorway pages). Cada uno aporta alcance específico,
 * consideraciones y normativa propias del servicio en ese sector.
 *
 * Enlaza al servicio padre y al sector (estructura de silos), y muestra el bloque
 * "solución llave en mano" cuando el cruce declara productos relacionados.
 * JSON-LD Service (desde el cruce) + BreadcrumbList.
 */
import { getCollection, getEntry, render } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import CTACotizacion from '../../../components/CTACotizacion.astro';
import {
  serviceJsonLd,
  breadcrumbJsonLd,
  type Breadcrumb,
} from '../../../lib/seo';

export async function getStaticPaths() {
  const cruces = await getCollection('cruces');
  return cruces.map((cruce) => ({
    params: { servicio: cruce.data.servicio.id, sector: cruce.data.sector.id },
    props: { cruce },
  }));
}

const { cruce } = Astro.props;
const { data } = cruce;
const { Content } = await render(cruce);

// Entradas relacionadas para el enlazado de silos.
const servicio = await getEntry(data.servicio);
const sector = await getEntry(data.sector);

const pageUrl = new URL(Astro.url.pathname, Astro.site).toString();

const migas: Breadcrumb[] = [
  { nombre: 'Inicio', href: '/' },
  { nombre: 'Servicios', href: '/servicios' },
  { nombre: servicio.data.titulo, href: `/servicios/${servicio.id}` },
  {
    nombre: data.titulo,
    href: `/servicios/${servicio.id}/${sector.id}`,
  },
];

// El JSON-LD Service se construye desde el cruce (alcance = alcanceEspecifico).
const jsonLd = [
  serviceJsonLd(
    { ...data, alcance: data.alcanceEspecifico },
    pageUrl,
    Astro.site!,
  ),
  breadcrumbJsonLd(migas, Astro.site!),
];
---

<BaseLayout
  title={data.titulo}
  description={data.descripcionSEO}
  image={servicio.data.imagen.src.src}
  jsonLd={jsonLd}
>
  <div class="mx-auto max-w-[var(--spacing-content)] px-4 py-10">
    <Breadcrumbs items={migas} />

    <header class="mt-6 grid gap-8 lg:grid-cols-2 lg:items-center">
      <div>
        <h1 class="text-4xl font-bold leading-tight text-ink">{data.titulo}</h1>
        <p class="mt-4 text-lg text-muted">{data.resumen}</p>
        <p class="mt-4 text-sm text-muted">
          Combinamos
          <a
            href={`/servicios/${servicio.id}`}
            class="text-accent-600 underline-offset-2 hover:text-accent-700 hover:underline"
            >{servicio.data.titulo}</a
          >
          con la experiencia en el
          <a
            href={`/sectores/${sector.id}`}
            class="text-accent-600 underline-offset-2 hover:text-accent-700 hover:underline"
            >{sector.data.titulo.toLowerCase()}</a
          >.
        </p>
      </div>
      <Image
        src={servicio.data.imagen.src}
        alt={servicio.data.imagen.alt}
        width={960}
        height={540}
        loading="eager"
        class="aspect-video w-full rounded-lg object-cover"
      />
    </header>

    <div class="mt-12 grid gap-12 lg:grid-cols-[2fr_1fr]">
      <article
        class="max-w-none [&_h2]:mt-8 [&_h2]:text-2xl [&_h2]:font-bold [&_h2]:text-ink [&_h3]:mt-6 [&_h3]:text-xl [&_h3]:font-semibold [&_h3]:text-ink [&_li]:mt-1 [&_p]:mt-4 [&_p]:leading-relaxed [&_p]:text-ink [&_ul]:mt-4 [&_ul]:list-disc [&_ul]:pl-6"
      >
        <Content />
      </article>

      <aside class="space-y-8">
        <section class="rounded-lg border border-line bg-surface-alt p-6">
          <h2 class="text-lg font-semibold text-ink">Qué incluye</h2>
          <ul class="mt-4 space-y-2">
            {
              data.alcanceEspecifico.map((item) => (
                <li class="flex gap-2 text-sm text-ink">
                  <span aria-hidden="true" class="text-accent-600">
                    ✓
                  </span>
                  <span>{item}</span>
                </li>
              ))
            }
          </ul>
        </section>

        <section class="rounded-lg border border-line p-6">
          <h2 class="text-lg font-semibold text-ink">Consideraciones</h2>
          <ul class="mt-4 space-y-2">
            {
              data.consideraciones.map((item) => (
                <li class="flex gap-2 text-sm text-ink">
                  <span aria-hidden="true" class="text-brand-500">
                    •
                  </span>
                  <span>{item}</span>
                </li>
              ))
            }
          </ul>
        </section>

        {
          data.normativa.length > 0 && (
            <section class="rounded-lg border border-line p-6">
              <h2 class="text-lg font-semibold text-ink">Normativa aplicable</h2>
              <ul class="mt-4 space-y-2">
                {data.normativa.map((item) => (
                  <li class="flex gap-2 text-sm text-ink">
                    <span aria-hidden="true" class="text-brand-500">
                      §
                    </span>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </section>
          )
        }
      </aside>
    </div>

    {/* Solución llave en mano: enlace a la tienda de materiales */}
    <section class="mt-12 flex flex-wrap items-center justify-between gap-4 rounded-xl border border-accent-200 bg-accent-50 p-6 md:p-8">
      <p class="max-w-2xl text-ink">
        Ejecutamos {data.titulo.toLowerCase()} y te suministramos los materiales
        necesarios bajo un mismo proveedor.
      </p>
      <a
        href="/tienda"
        class="inline-block shrink-0 rounded-md bg-accent-600 px-6 py-3 font-semibold text-white shadow-card transition hover:-translate-y-0.5 hover:bg-accent-700"
      >
        Ver la tienda →
      </a>
    </section>

    {/* Navegación de silos */}
    <nav
      aria-label="Servicio y sector relacionados"
      class="mt-12 grid gap-4 sm:grid-cols-2"
    >
      <a
        href={`/servicios/${servicio.id}`}
        class="hover-lift group rounded-xl border border-line bg-surface p-5 shadow-card hover:border-brand-300"
      >
        <span class="text-sm text-muted">Servicio</span>
        <span class="mt-1 block font-semibold text-brand-700 group-hover:text-accent-600">
          {servicio.data.titulo}
        </span>
      </a>
      <a
        href={`/sectores/${sector.id}`}
        class="hover-lift group rounded-xl border border-line bg-surface p-5 shadow-card hover:border-brand-300"
      >
        <span class="text-sm text-muted">Sector</span>
        <span class="mt-1 block font-semibold text-brand-700 group-hover:text-accent-600">
          {sector.data.titulo}
        </span>
      </a>
    </nav>

    <CTACotizacion titulo={`¿Necesitas ${data.keywordPrimaria}?`} />
  </div>
</BaseLayout>
