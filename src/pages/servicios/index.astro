---
/**
 * Índice del silo SERVICIOS (CLAUDE.md §4). Lista todas las pillar pages.
 */
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { breadcrumbJsonLd, type Breadcrumb } from '../../lib/seo';

const servicios = (await getCollection('servicios')).sort(
  (a, b) => a.data.orden - b.data.orden,
);

const migas: Breadcrumb[] = [
  { nombre: 'Inicio', href: '/' },
  { nombre: 'Servicios', href: '/servicios' },
];

const title = 'Servicios generales: limpieza, mantenimiento y saneamiento';
const description =
  'Conoce los servicios generales de FEGHADAL en el Perú: limpieza empresarial, ' +
  'mantenimiento de inmuebles, instalaciones y saneamiento ambiental para empresas.';
---

<BaseLayout
  title={title}
  description={description}
  jsonLd={[breadcrumbJsonLd(migas, Astro.site!)]}
>
  <div class="mx-auto max-w-[var(--spacing-content)] px-4 py-10">
    <Breadcrumbs items={migas} />
    <h1 class="mt-6 text-4xl font-bold text-ink">Servicios generales</h1>
    <p class="mt-3 max-w-2xl text-lg text-muted">
      Soluciones integrales para mantener tus instalaciones limpias, operativas y
      seguras, con un solo proveedor.
    </p>

    <ul class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        servicios.map((servicio) => (
          <li class="overflow-hidden rounded-lg border border-line bg-surface">
            <a href={`/servicios/${servicio.id}`} class="group block">
              <Image
                src={servicio.data.imagen.src}
                alt={servicio.data.imagen.alt}
                width={600}
                height={338}
                class="aspect-video w-full object-cover"
              />
              <div class="p-5">
                <h2 class="text-lg font-semibold text-brand-700 group-hover:underline">
                  {servicio.data.titulo}
                </h2>
                <p class="mt-2 text-sm text-muted">{servicio.data.resumen}</p>
              </div>
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</BaseLayout>
