---
/**
 * Índice del silo SECTORES (CLAUDE.md §4).
 */
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { breadcrumbJsonLd, type Breadcrumb } from '../../lib/seo';

const sectores = (await getCollection('sectores')).sort(
  (a, b) => a.data.orden - b.data.orden,
);

const migas: Breadcrumb[] = [
  { nombre: 'Inicio', href: '/' },
  { nombre: 'Sectores', href: '/sectores' },
];

const title = 'Sectores que atendemos: oficinas, salud, educación y Estado';
const description =
  'Servicios generales de FEGHADAL adaptados a cada sector en el Perú: oficinas y ' +
  'retail, salud, educación y entidades del Estado, con experiencia y cumplimiento.';
---

<BaseLayout
  title={title}
  description={description}
  jsonLd={[breadcrumbJsonLd(migas, Astro.site!)]}
>
  <div class="mx-auto max-w-[var(--spacing-content)] px-4 py-10">
    <Breadcrumbs items={migas} />
    <div class="reveal">
      <h1 class="mt-6 text-4xl font-bold text-brand-700">Sectores que atendemos</h1>
      <p class="mt-3 max-w-2xl text-lg text-muted">
        Adaptamos cada servicio a las exigencias específicas de tu sector, con personal
        capacitado y cumplimiento normativo.
      </p>
    </div>

    <ul class="stagger mt-10 grid gap-6 sm:grid-cols-2">
      {
        sectores.map((sector) => (
          <li class="reveal hover-lift overflow-hidden rounded-xl border border-line bg-surface shadow-card">
            <a href={`/sectores/${sector.id}`} class="group block">
              <Image
                src={sector.data.imagen.src}
                alt={sector.data.imagen.alt}
                width={600}
                height={338}
                class="aspect-video w-full object-cover"
              />
              <div class="p-5">
                <h2 class="text-lg font-semibold text-brand-700 group-hover:text-accent-600">
                  {sector.data.titulo}
                </h2>
                <p class="mt-2 text-sm text-muted">{sector.data.resumen}</p>
              </div>
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</BaseLayout>
