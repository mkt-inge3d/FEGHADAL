---
/**
 * Página de sector (CLAUDE.md §4, §5).
 * Render desde la collection `sectores`. Muestra: retos del sector, servicios que lo
 * resuelven (enlace al silo servicios), cruces específicos disponibles y por qué
 * elegirnos. JSON-LD BreadcrumbList (la entidad va como LocalBusiness global).
 */
import { getCollection, getEntry, render } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { breadcrumbJsonLd, type Breadcrumb } from '../../lib/seo';

export async function getStaticPaths() {
  const sectores = await getCollection('sectores');
  return sectores.map((sector) => ({
    params: { slug: sector.id },
    props: { sector },
  }));
}

const { sector } = Astro.props;
const { data } = sector;
const { Content } = await render(sector);

// Servicios que resuelven los retos del sector (enlazado de silos).
const serviciosRelacionados = (
  await Promise.all(data.serviciosRelacionados.map((ref) => getEntry(ref)))
).filter((s) => s !== undefined);

// Cruces específicos que tienen a este sector como destino.
const cruces = (await getCollection('cruces')).filter(
  (c) => c.data.sector.id === sector.id,
);

const migas: Breadcrumb[] = [
  { nombre: 'Inicio', href: '/' },
  { nombre: 'Sectores', href: '/sectores' },
  { nombre: data.titulo, href: `/sectores/${sector.id}` },
];

const jsonLd = [breadcrumbJsonLd(migas, Astro.site!)];
---

<BaseLayout
  title={`${data.titulo}: ${data.keywordPrimaria}`}
  description={data.descripcionSEO}
  image={data.imagen.src.src}
  jsonLd={jsonLd}
>
  <div class="mx-auto max-w-[var(--spacing-content)] px-4 py-10">
    <Breadcrumbs items={migas} />

    <header class="mt-6 grid gap-8 lg:grid-cols-2 lg:items-center">
      <div>
        <h1 class="text-4xl font-bold leading-tight text-ink">{data.titulo}</h1>
        <p class="mt-4 text-lg text-muted">{data.resumen}</p>
      </div>
      <Image
        src={data.imagen.src}
        alt={data.imagen.alt}
        width={960}
        height={540}
        loading="eager"
        class="aspect-video w-full rounded-lg object-cover"
      />
    </header>

    <div class="mt-12 grid gap-12 lg:grid-cols-[2fr_1fr]">
      <article
        class="max-w-none [&_h2]:mt-8 [&_h2]:text-2xl [&_h2]:font-bold [&_h2]:text-ink [&_h3]:mt-6 [&_h3]:text-xl [&_h3]:font-semibold [&_h3]:text-ink [&_li]:mt-1 [&_p]:mt-4 [&_p]:leading-relaxed [&_p]:text-ink [&_ul]:mt-4 [&_ul]:list-disc [&_ul]:pl-6"
      >
        <Content />
      </article>

      <aside class="space-y-8">
        <section class="rounded-lg border border-line bg-surface-alt p-6">
          <h2 class="text-lg font-semibold text-ink">Retos del sector</h2>
          <ul class="mt-4 space-y-2">
            {
              data.retos.map((reto) => (
                <li class="flex gap-2 text-sm text-ink">
                  <span aria-hidden="true" class="text-brand-500">
                    •
                  </span>
                  <span>{reto}</span>
                </li>
              ))
            }
          </ul>
        </section>

        {
          serviciosRelacionados.length > 0 && (
            <nav
              aria-label="Servicios para este sector"
              class="rounded-lg border border-line p-6"
            >
              <h2 class="text-lg font-semibold text-ink">
                Servicios que lo resuelven
              </h2>
              <ul class="mt-4 space-y-2">
                {serviciosRelacionados.map((servicio) => (
                  <li>
                    <a
                      href={`/servicios/${servicio.id}`}
                      class="text-sm text-brand-700 underline-offset-2 hover:underline"
                    >
                      {servicio.data.titulo}
                    </a>
                  </li>
                ))}
              </ul>
            </nav>
          )
        }
      </aside>
    </div>

    {
      cruces.length > 0 && (
        <section class="mt-12">
          <h2 class="text-2xl font-bold text-ink">
            Soluciones específicas para {data.titulo.toLowerCase()}
          </h2>
          <ul class="mt-6 grid gap-4 sm:grid-cols-2">
            {cruces.map((cruce) => (
              <li>
                <a
                  href={`/servicios/${cruce.data.servicio.id}/${cruce.data.sector.id}`}
                  class="group flex h-full flex-col rounded-lg border border-line bg-surface p-5 hover:border-brand-300"
                >
                  <span class="font-semibold text-brand-700 group-hover:underline">
                    {cruce.data.titulo}
                  </span>
                  <span class="mt-1 text-sm text-muted">{cruce.data.resumen}</span>
                </a>
              </li>
            ))}
          </ul>
        </section>
      )
    }

    {/* Por qué elegirnos / CTA */}
    <section class="mt-12 rounded-lg bg-brand-700 p-8 text-white md:p-12">
      <h2 class="text-2xl font-bold">¿Por qué elegir a FEGHADAL?</h2>
      <p class="mt-3 max-w-2xl text-brand-100">
        Integramos todos los servicios generales bajo un mismo proveedor, con personal
        capacitado, supervisión y cumplimiento de SST. Listos para el sector privado y
        para contrataciones con el Estado peruano.
      </p>
      <a
        href="/nosotros"
        class="mt-6 inline-block rounded-md bg-accent-500 px-6 py-3 font-semibold text-white hover:bg-accent-600"
      >
        Conoce a FEGHADAL
      </a>
    </section>
  </div>
</BaseLayout>
