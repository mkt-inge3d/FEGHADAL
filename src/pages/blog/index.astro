---
/**
 * Índice del BLOG (CLAUDE.md §4 silo AUTORIDAD).
 * Lista artículos publicados (no draft) y ofrece filtro por categoría mediante
 * páginas estáticas /blog/categoria/[categoria] (sin JS).
 */
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { breadcrumbJsonLd, type Breadcrumb } from '../../lib/seo';
import { slugify } from '../../lib/text';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.fecha.getTime() - a.data.fecha.getTime(),
);

// Categorías únicas para el filtro.
const categorias = [...new Set(posts.map((p) => p.data.categoria))].sort();

const fmtFecha = (d: Date) =>
  d.toLocaleDateString('es-PE', { year: 'numeric', month: 'long', day: 'numeric' });

const migas: Breadcrumb[] = [
  { nombre: 'Inicio', href: '/' },
  { nombre: 'Blog', href: '/blog' },
];

const title = 'Blog: recursos sobre servicios generales y mantenimiento';
const description =
  'Artículos y guías de FEGHADAL sobre servicios generales, mantenimiento, limpieza ' +
  'y materiales para empresas en el Perú. Aprende a elegir y contratar mejor.';
---

<BaseLayout
  title={title}
  description={description}
  jsonLd={[breadcrumbJsonLd(migas, Astro.site!)]}
>
  <div class="mx-auto max-w-[var(--spacing-content)] px-4 py-10">
    <Breadcrumbs items={migas} />
    <div class="reveal">
      <h1 class="mt-6 text-4xl font-bold text-brand-700">Blog</h1>
      <p class="mt-3 max-w-2xl text-lg text-muted">
        Guías prácticas para elegir y contratar servicios generales y materiales.
      </p>
    </div>

    {/* Filtro por categoría */}
    <nav aria-label="Filtrar por categoría" class="mt-8">
      <ul class="flex flex-wrap gap-2">
        <li>
          <a
            href="/blog"
            aria-current="page"
            class="inline-block rounded-full bg-brand-700 px-4 py-2 text-sm font-medium text-white"
          >
            Todas
          </a>
        </li>
        {
          categorias.map((cat) => (
            <li>
              <a
                href={`/blog/categoria/${slugify(cat)}`}
                class="inline-block rounded-full border border-line px-4 py-2 text-sm text-accent-600 hover:border-accent-400 hover:bg-accent-50 hover:text-accent-700"
              >
                {cat}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <ul class="stagger mt-10 grid gap-6 sm:grid-cols-2">
      {
        posts.map((post) => (
          <li class="reveal hover-lift flex flex-col rounded-xl border border-line bg-surface p-6 shadow-card">
            <p class="text-xs uppercase tracking-wide text-accent-700">
              {post.data.categoria}
            </p>
            <h2 class="mt-2 text-lg font-semibold text-brand-700">
              <a
                href={`/blog/${post.id}`}
                class="underline-offset-2 hover:text-accent-600 hover:underline"
              >
                {post.data.titulo}
              </a>
            </h2>
            <p class="mt-2 flex-1 text-sm text-muted">{post.data.descripcionSEO}</p>
            <p class="mt-4 text-xs text-muted">
              <time datetime={post.data.fecha.toISOString()}>
                {fmtFecha(post.data.fecha)}
              </time>
            </p>
          </li>
        ))
      }
    </ul>
  </div>
</BaseLayout>
