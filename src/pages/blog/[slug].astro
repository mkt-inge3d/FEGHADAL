---
/**
 * Detalle de artículo del blog (CLAUDE.md §4, §5).
 * Solo se generan posts publicados (no draft). H1 = título (con la keyword).
 * JSON-LD Article + BreadcrumbList. CTA a cotización.
 */
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import CTACotizacion from '../../components/CTACotizacion.astro';
import {
  articleJsonLd,
  breadcrumbJsonLd,
  type Breadcrumb,
} from '../../lib/seo';
import { slugify } from '../../lib/text';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { data } = post;
const { Content } = await render(post);

const pageUrl = new URL(Astro.url.pathname, Astro.site).toString();

const fmtFecha = (d: Date) =>
  d.toLocaleDateString('es-PE', { year: 'numeric', month: 'long', day: 'numeric' });

const migas: Breadcrumb[] = [
  { nombre: 'Inicio', href: '/' },
  { nombre: 'Blog', href: '/blog' },
  { nombre: data.titulo, href: `/blog/${post.id}` },
];

const jsonLd = [
  articleJsonLd(data, pageUrl, Astro.site!),
  breadcrumbJsonLd(migas, Astro.site!),
];
---

<BaseLayout
  title={data.titulo}
  description={data.descripcionSEO}
  type="article"
  jsonLd={jsonLd}
>
  <div class="mx-auto max-w-3xl px-4 py-10">
    <Breadcrumbs items={migas} />

    <header class="mt-6">
      <p class="text-xs uppercase tracking-wide text-accent-700">
        <a
          href={`/blog/categoria/${slugify(data.categoria)}`}
          class="underline-offset-2 hover:underline"
        >
          {data.categoria}
        </a>
      </p>
      <h1 class="mt-2 text-4xl font-bold leading-tight text-ink">{data.titulo}</h1>
      <p class="mt-3 text-sm text-muted">
        Por {data.autor} ·
        <time datetime={data.fecha.toISOString()}>{fmtFecha(data.fecha)}</time>
      </p>
    </header>

    <article
      class="mt-8 max-w-none [&_a]:text-brand-700 [&_a]:underline [&_a]:underline-offset-2 [&_h2]:mt-8 [&_h2]:text-2xl [&_h2]:font-bold [&_h2]:text-ink [&_li]:mt-1 [&_p]:mt-4 [&_p]:leading-relaxed [&_p]:text-ink [&_ul]:mt-4 [&_ul]:list-disc [&_ul]:pl-6"
    >
      <Content />
    </article>

    <CTACotizacion />
  </div>
</BaseLayout>
