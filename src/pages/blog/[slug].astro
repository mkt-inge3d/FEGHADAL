---
/**
 * Detalle de artículo del blog (CLAUDE.md §4, §5, §blog E-E-A-T).
 * Solo se generan posts publicados (no draft). H1 = título (con la keyword).
 * Byline visible + ficha de autor (Person) al pie. JSON-LD Article (author Person)
 * + BreadcrumbList. CTA a la pillar relacionada + cotización.
 */
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import AutorBio from '../../components/AutorBio.astro';
import CTACotizacion from '../../components/CTACotizacion.astro';
import {
  articleJsonLd,
  breadcrumbJsonLd,
  type Breadcrumb,
} from '../../lib/seo';
import { getAutor } from '../../config/autores';
import { slugify } from '../../lib/text';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { data } = post;
const { Content } = await render(post);

const autor = getAutor(data.autor);
const pageUrl = new URL(Astro.url.pathname, Astro.site).toString();

const migas: Breadcrumb[] = [
  { nombre: 'Inicio', href: '/' },
  { nombre: 'Blog', href: '/blog' },
  { nombre: data.titulo, href: `/blog/${post.id}` },
];

const jsonLd = [
  articleJsonLd(data, pageUrl, Astro.site!, autor),
  breadcrumbJsonLd(migas, Astro.site!),
];
---

<BaseLayout
  title={data.titulo}
  description={data.descripcionSEO}
  type="article"
  image={data.imagen?.src.src}
  jsonLd={jsonLd}
>
  <div class="mx-auto max-w-3xl px-4 py-10">
    <Breadcrumbs items={migas} />

    <header class="mt-6">
      <p class="text-xs uppercase tracking-wide">
        <a
          href={`/blog/categoria/${slugify(data.categoria)}`}
          class="text-accent-600 underline-offset-2 hover:text-accent-700 hover:underline"
        >
          {data.categoria}
        </a>
      </p>
      <h1 class="mt-2 text-4xl font-bold leading-tight text-ink">{data.titulo}</h1>
      {/* Byline E-E-A-T */}
      <AutorBio
        autor={data.autor}
        variant="byline"
        fecha={data.fecha}
        actualizado={data.actualizado}
      />
    </header>

    {/* Imagen propia del artículo (FOTO REAL) — opcional hasta tenerla; nunca stock. */}
    {
      data.imagen && (
        <Image
          src={data.imagen.src}
          alt={data.imagen.alt}
          width={960}
          height={540}
          loading="eager"
          class="mt-6 aspect-video w-full rounded-xl object-cover"
        />
      )
    }

    <article
      class="mt-8 max-w-none [&_a]:text-accent-600 [&_a]:underline [&_a]:underline-offset-2 [&_a:hover]:text-accent-700 [&_h2]:mt-8 [&_h2]:text-2xl [&_h2]:font-bold [&_h2]:text-ink [&_h3]:mt-6 [&_h3]:text-xl [&_h3]:font-semibold [&_h3]:text-ink [&_li]:mt-1 [&_p]:mt-4 [&_p]:leading-relaxed [&_p]:text-ink [&_ul]:mt-4 [&_ul]:list-disc [&_ul]:pl-6"
    >
      <Content />
    </article>

    {/* Enlace interno a la pillar relacionada (silo SEO) */}
    {
      data.pillar && (
        <p class="mt-8 rounded-xl border border-accent-200 bg-accent-50 p-5 text-ink">
          ¿Te interesa este servicio?{' '}
          <a
            href={data.pillar}
            class="font-semibold text-accent-600 underline underline-offset-2 hover:text-accent-700"
          >
            {data.pillarTitulo ?? 'Conoce más en nuestra página'} →
          </a>
        </p>
      )
    }

    {/* Ficha del autor (E-E-A-T) */}
    <AutorBio autor={data.autor} variant="full" />

    <CTACotizacion />
  </div>
</BaseLayout>
