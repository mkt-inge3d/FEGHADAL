---
/**
 * Índice de PROYECTOS / portafolio (CLAUDE.md §4, §8 regla de honestidad).
 * FEGHADAL es una empresa nueva: NO se inventan casos. Si no hay casos reales,
 * se muestra un estado honesto orientado a capacidades, alcance y forma de trabajo,
 * y las entradas marcadas como plantilla se rotulan claramente.
 */
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import CTACotizacion from '../../components/CTACotizacion.astro';
import { breadcrumbJsonLd, type Breadcrumb } from '../../lib/seo';

const todos = await getCollection('proyectos');
const reales = todos.filter((p) => !p.data.esPlantilla);
const plantillas = todos.filter((p) => p.data.esPlantilla);

const migas: Breadcrumb[] = [
  { nombre: 'Inicio', href: '/' },
  { nombre: 'Proyectos', href: '/proyectos' },
];

const comoTrabajamos = [
  'Evaluación en sitio y propuesta a medida',
  'Personal capacitado y en planilla, con SST',
  'Supervisión permanente con checklists y reportes',
  'Suministro de materiales (solución llave en mano)',
  'Respaldo documentario y trazabilidad del servicio',
];

const title = 'Proyectos y forma de trabajo de FEGHADAL';
const description =
  'Conoce cómo trabaja FEGHADAL: alcance, garantías y metodología de servicios ' +
  'generales y materiales en Lima Norte. Casos en desarrollo; solicita referencias.';
---

<BaseLayout
  title={title}
  description={description}
  jsonLd={[breadcrumbJsonLd(migas, Astro.site!)]}
>
  <div class="mx-auto max-w-[var(--spacing-content)] px-4 py-10">
    <Breadcrumbs items={migas} />
    <h1 class="mt-6 text-4xl font-bold text-ink">Proyectos</h1>

    {
      reales.length > 0 ? (
        <ul class="mt-8 grid gap-6 sm:grid-cols-2">
          {reales.map((p) => (
            <li class="rounded-lg border border-line bg-surface p-6">
              <h2 class="text-lg font-semibold text-brand-700">
                <a
                  href={`/proyectos/${p.id}`}
                  class="underline-offset-2 hover:underline"
                >
                  {p.data.titulo}
                </a>
              </h2>
              <p class="mt-2 text-sm text-muted">{p.data.alcance}</p>
            </li>
          ))}
        </ul>
      ) : (
        <div class="mt-6 rounded-lg border border-line bg-surface-alt p-6">
          <p class="text-lg font-semibold text-ink">
            Casos en desarrollo — solicita referencias
          </p>
          <p class="mt-2 max-w-2xl text-muted">
            FEGHADAL es una empresa en crecimiento. Estamos documentando nuestros
            primeros casos con resultados verificables. Mientras tanto, conoce nuestra
            forma de trabajo y
            <a
              href="/contacto"
              class="text-brand-700 underline-offset-2 hover:underline"
            >
              solicita referencias
            </a>
            de los servicios que te interesan.
          </p>
        </div>
      )
    }

    {/* Forma de trabajo / garantías (el foco cuando aún no hay casos) */}
    <section class="mt-12">
      <h2 class="text-2xl font-bold text-ink">Cómo trabajamos</h2>
      <ul class="mt-6 grid gap-3 sm:grid-cols-2">
        {
          comoTrabajamos.map((item) => (
            <li class="flex gap-2 rounded-md border border-line bg-surface p-4 text-sm text-ink">
              <span aria-hidden="true" class="text-accent-600">
                ✓
              </span>
              <span>{item}</span>
            </li>
          ))
        }
      </ul>
    </section>

    {/* Plantillas de ejemplo, claramente rotuladas */}
    {
      plantillas.length > 0 && (
        <section class="mt-12">
          <h2 class="text-2xl font-bold text-ink">Plantilla de caso (ejemplo)</h2>
          <p class="mt-2 text-sm text-muted">
            Estructura de referencia para documentar proyectos reales. No representa un
            cliente ni un resultado real.
          </p>
          <ul class="mt-6 grid gap-6 sm:grid-cols-2">
            {plantillas.map((p) => (
              <li class="rounded-lg border border-dashed border-line bg-surface p-6">
                <span class="inline-block rounded-full bg-surface-alt px-3 py-1 text-xs font-semibold text-muted">
                  Plantilla de ejemplo
                </span>
                <h3 class="mt-3 text-lg font-semibold text-brand-700">
                  <a
                    href={`/proyectos/${p.id}`}
                    class="underline-offset-2 hover:underline"
                  >
                    {p.data.titulo}
                  </a>
                </h3>
                <p class="mt-2 text-sm text-muted">{p.data.alcance}</p>
              </li>
            ))}
          </ul>
        </section>
      )
    }

    <CTACotizacion />
  </div>
</BaseLayout>
