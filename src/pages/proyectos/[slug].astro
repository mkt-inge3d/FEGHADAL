---
/**
 * Detalle de proyecto (CLAUDE.md §4). Render desde la collection `proyectos`.
 * Si la entrada es plantilla (esPlantilla), muestra un aviso claro (honestidad §8).
 * Enlaza a los servicios y al sector involucrados. JSON-LD BreadcrumbList.
 */
import { getCollection, getEntry, render } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import CTACotizacion from '../../components/CTACotizacion.astro';
import { breadcrumbJsonLd, type Breadcrumb } from '../../lib/seo';

export async function getStaticPaths() {
  const proyectos = await getCollection('proyectos');
  return proyectos.map((proyecto) => ({
    params: { slug: proyecto.id },
    props: { proyecto },
  }));
}

const { proyecto } = Astro.props;
const { data } = proyecto;
const { Content } = await render(proyecto);

const sector = await getEntry(data.sector);
const servicios = (
  await Promise.all(data.servicios.map((ref) => getEntry(ref)))
).filter((s) => s !== undefined);

const migas: Breadcrumb[] = [
  { nombre: 'Inicio', href: '/' },
  { nombre: 'Proyectos', href: '/proyectos' },
  { nombre: data.titulo, href: `/proyectos/${proyecto.id}` },
];

const portada = data.imagenes[0];
---

<BaseLayout
  title={data.titulo}
  description={data.descripcionSEO}
  image={portada?.src.src}
  noindex={data.esPlantilla}
  jsonLd={[breadcrumbJsonLd(migas, Astro.site!)]}
>
  <div class="mx-auto max-w-[var(--spacing-content)] px-4 py-10">
    <Breadcrumbs items={migas} />

    {
      data.esPlantilla && (
        <p class="mt-6 rounded-md border border-dashed border-line bg-surface-alt p-4 text-sm text-muted">
          <strong class="text-ink">Plantilla de ejemplo.</strong> Esta ficha es una
          estructura de referencia y no representa un cliente ni un resultado real.
        </p>
      )
    }

    <header class="mt-6">
      <h1 class="text-4xl font-bold leading-tight text-ink">{data.titulo}</h1>
      <p class="mt-3 text-lg text-muted">{data.alcance}</p>
    </header>

    {
      portada && (
        <Image
          src={portada.src}
          alt={portada.alt}
          width={1200}
          height={675}
          loading="eager"
          class="mt-8 aspect-video w-full rounded-lg object-cover"
        />
      )
    }

    <div class="mt-12 grid gap-12 lg:grid-cols-[2fr_1fr]">
      <article
        class="max-w-none [&_blockquote]:mt-4 [&_blockquote]:border-l-4 [&_blockquote]:border-line [&_blockquote]:pl-4 [&_blockquote]:text-muted [&_h2]:mt-8 [&_h2]:text-2xl [&_h2]:font-bold [&_h2]:text-ink [&_p]:mt-4 [&_p]:leading-relaxed [&_p]:text-ink"
      >
        <Content />
      </article>

      <aside class="space-y-8">
        <section class="rounded-lg border border-line bg-surface-alt p-6">
          <h2 class="text-lg font-semibold text-ink">Ficha</h2>
          <dl class="mt-4 space-y-3 text-sm">
            <div>
              <dt class="text-xs uppercase tracking-wide text-muted">Cliente</dt>
              <dd class="text-ink">{data.cliente}</dd>
            </div>
            <div>
              <dt class="text-xs uppercase tracking-wide text-muted">Año</dt>
              <dd class="text-ink">{data.anio}</dd>
            </div>
            <div>
              <dt class="text-xs uppercase tracking-wide text-muted">Sector</dt>
              <dd>
                <a
                  href={`/sectores/${sector.id}`}
                  class="text-brand-700 underline-offset-2 hover:underline"
                >
                  {sector.data.titulo}
                </a>
              </dd>
            </div>
            <div>
              <dt class="text-xs uppercase tracking-wide text-muted">Resultado</dt>
              <dd class="text-ink">{data.resultado}</dd>
            </div>
          </dl>
        </section>

        {
          servicios.length > 0 && (
            <nav
              aria-label="Servicios del proyecto"
              class="rounded-lg border border-line p-6"
            >
              <h2 class="text-lg font-semibold text-ink">Servicios aplicados</h2>
              <ul class="mt-4 space-y-2">
                {servicios.map((servicio) => (
                  <li>
                    <a
                      href={`/servicios/${servicio.id}`}
                      class="text-sm text-brand-700 underline-offset-2 hover:underline"
                    >
                      {servicio.data.titulo}
                    </a>
                  </li>
                ))}
              </ul>
            </nav>
          )
        }
      </aside>
    </div>

    <CTACotizacion />
  </div>
</BaseLayout>
