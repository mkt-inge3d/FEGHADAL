---
/**
 * Layout base de todas las páginas (CLAUDE.md §3, §5, §6).
 * - <html lang="es-PE">, skip link, header, main, footer.
 * - Inyecta SEO + JSON-LD global (Organization/LocalBusiness).
 * - Las páginas pueden añadir bloques JSON-LD adicionales (Service, Breadcrumb...).
 */
import '../styles/global.css';
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import { organizationJsonLd } from '../lib/seo';

interface Props {
  title: string;
  description: string;
  type?: 'website' | 'article';
  image?: string;
  canonical?: string;
  /** Bloques JSON-LD específicos de la página (Service, BreadcrumbList...). */
  jsonLd?: Record<string, unknown>[];
  /** Excluir del índice (ej. /gracias). */
  noindex?: boolean;
}

const {
  title,
  description,
  type,
  image,
  canonical,
  jsonLd = [],
  noindex = false,
} = Astro.props;

// Organization/LocalBusiness va en todas las páginas.
const allJsonLd = [organizationJsonLd(Astro.site!), ...jsonLd];
---

<!doctype html>
<html lang="es-PE">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    {/* Marca JS disponible ANTES del paint: habilita el reveal sin flash de contenido. */}
    <script is:inline>document.documentElement.classList.add('js');</script>
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <SEO
      title={title}
      description={description}
      type={type}
      image={image}
      canonical={canonical}
      jsonLd={allJsonLd}
      noindex={noindex}
    />
  </head>
  <body class="flex min-h-screen flex-col bg-surface text-ink">
    <a href="#main" class="skip-link">Saltar al contenido</a>
    <Header />
    <main id="main" class="flex-1">
      <slot />
    </main>
    <Footer />
    <WhatsAppButton />

    {/* Reveal on-scroll (isla JS mínima, documentada en CLAUDE.md §2). Respeta
        prefers-reduced-motion; si no hay soporte, muestra todo de inmediato. */}
    <script>
      const prefiereMovimiento = window.matchMedia(
        '(prefers-reduced-motion: no-preference)',
      ).matches;
      const elementos = document.querySelectorAll('.reveal');

      if (prefiereMovimiento && 'IntersectionObserver' in window) {
        const observador = new IntersectionObserver(
          (entradas, obs) => {
            for (const entrada of entradas) {
              if (entrada.isIntersecting) {
                entrada.target.classList.add('is-visible');
                obs.unobserve(entrada.target);
              }
            }
          },
          { rootMargin: '0px 0px -10% 0px', threshold: 0.1 },
        );
        elementos.forEach((el) => observador.observe(el));
      } else {
        elementos.forEach((el) => el.classList.add('is-visible'));
      }
    </script>
  </body>
</html>
