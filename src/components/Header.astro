---
/**
 * Cabecera con navegación de los 3 silos (CLAUDE.md §4, §6).
 * Menú móvil con <details>/<summary>: accesible y SIN JavaScript de cliente.
 * Marca la página activa con aria-current="page".
 */
import { Image } from 'astro:assets';
import { site, navPrincipal } from '../config/site';
import RedesSociales from './RedesSociales.astro';
import wordmark from '../assets/brand/wordmark-blanco.png';

const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? path === '/' : path === href || path.startsWith(href + '/');
---

<header
  class="sticky top-0 z-40 border-b border-white/10 bg-brand-950/90 text-white shadow-card backdrop-blur"
>
  <div
    class="mx-auto flex max-w-[var(--spacing-content)] items-center justify-between gap-4 px-4 py-4"
  >
    <a href="/" aria-label={`${site.nombre} — inicio`} class="inline-flex">
      <Image
        src={wordmark}
        alt="FEGHADAL — Servicios Generales"
        width={945}
        height={85}
        loading="eager"
        class="h-3.5 w-auto sm:h-4"
      />
    </a>

    {/* Navegación de escritorio */}
    <nav aria-label="Navegación principal" class="hidden md:block">
      <ul class="flex items-center gap-6">
        {
          navPrincipal.map((item) => (
            <li>
              <a
                href={item.href}
                aria-current={isActive(item.href) ? 'page' : undefined}
                class:list={[
                  'text-base font-medium underline-offset-4 hover:text-accent-300 hover:underline',
                  isActive(item.href) ? 'font-semibold text-accent-300' : 'text-brand-100',
                ]}
              >
                {item.titulo}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    {/* Navegación móvil sin JS */}
    <details class="relative md:hidden">
      <summary
        class="flex cursor-pointer list-none items-center gap-2 rounded-md border border-white/20 px-3 py-2 text-sm font-medium text-white hover:bg-white/10 [&::-webkit-details-marker]:hidden"
        aria-label="Abrir menú de navegación"
      >
        <span aria-hidden="true">☰</span> Menú
      </summary>
      <nav
        aria-label="Navegación principal"
        class="absolute right-0 z-50 mt-2 w-56 rounded-md border border-white/10 bg-brand-950 p-2 shadow-lg"
      >
        <ul class="flex flex-col">
          {
            navPrincipal.map((item) => (
              <li>
                <a
                  href={item.href}
                  aria-current={isActive(item.href) ? 'page' : undefined}
                  class:list={[
                    'block rounded px-3 py-2 text-base hover:bg-white/10',
                    isActive(item.href)
                      ? 'font-semibold text-accent-300'
                      : 'text-brand-100',
                  ]}
                >
                  {item.titulo}
                </a>
              </li>
            ))
          }
        </ul>
        {/* Redes sociales en el panel móvil (se ocultan si no hay URLs, §13). */}
        <RedesSociales
        class="mt-2 flex items-center gap-1 border-t border-white/10 pt-2"
        linkClass="text-brand-100 hover:bg-white/10 hover:text-white"
      />
      </nav>
    </details>
  </div>
</header>
