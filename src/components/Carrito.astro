---
/**
 * Carrito de pedido (CLAUDE.md §2 isla JS justificada, §tienda).
 * - Botón flotante (abajo-izquierda, no choca con el FAB de WhatsApp) con contador.
 * - Drawer accesible (role=dialog, Escape, foco) con lista, cantidades y total.
 * - "Realizar pedido" arma un mensaje de WhatsApp con los ítems, precios y total
 *   (o solicitud de cotización si no hay precios) y abre wa.me.
 * Estado en localStorage (persiste entre páginas). Sin backend.
 */
import { site } from '../config/site';
---

<div id="carrito" data-whatsapp={site.whatsapp.numero}>
  {/* Botón flotante */}
  <button
    id="carrito-toggle"
    type="button"
    aria-label="Ver mi pedido"
    aria-haspopup="dialog"
    class="fixed bottom-5 left-5 z-50 flex h-14 items-center gap-2 rounded-full bg-brand-700 px-5 text-white shadow-lg transition hover:bg-brand-800"
  >
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6" aria-hidden="true">
      <circle cx="9" cy="21" r="1"></circle>
      <circle cx="20" cy="21" r="1"></circle>
      <path d="M1 1h4l2.7 13.4a2 2 0 0 0 2 1.6h9.7a2 2 0 0 0 2-1.6L23 6H6"></path>
    </svg>
    <span class="text-sm font-semibold">Mi pedido</span>
    <span
      id="carrito-count"
      class="ml-1 hidden min-w-[1.5rem] rounded-full bg-accent-600 px-1.5 py-0.5 text-center text-xs font-bold"
    >0</span>
  </button>

  {/* Overlay */}
  <div id="carrito-overlay" class="fixed inset-0 z-[60] hidden bg-brand-900/50 backdrop-blur-sm"></div>

  {/* Drawer */}
  <aside
    id="carrito-panel"
    role="dialog"
    aria-modal="true"
    aria-label="Mi pedido"
    class="fixed right-0 top-0 z-[70] flex h-full w-full max-w-md translate-x-full flex-col bg-surface shadow-2xl transition-transform duration-300"
  >
    <header class="flex items-center justify-between border-b border-line bg-brand-700 px-5 py-4 text-white">
      <h2 class="text-lg font-bold">Mi pedido</h2>
      <button id="carrito-cerrar" type="button" aria-label="Cerrar" class="rounded p-1 text-2xl leading-none hover:bg-brand-600">×</button>
    </header>

    <div id="carrito-items" class="flex-1 overflow-y-auto p-5">
      {/* Render dinámico por JS */}
    </div>

    <footer class="border-t border-line p-5">
      <div class="flex items-center justify-between text-base">
        <span class="font-medium text-muted">Total</span>
        <span id="carrito-total" class="text-xl font-bold text-ink">S/ 0.00</span>
      </div>
      <p id="carrito-nota" class="mt-1 hidden text-xs text-muted">
        Algunos productos se cotizan; te confirmamos el precio por WhatsApp.
      </p>
      <button
        id="carrito-pedido"
        type="button"
        class="mt-4 flex w-full items-center justify-center gap-2 rounded-md bg-whatsapp px-5 py-3 font-semibold text-white transition hover:bg-whatsapp-700 disabled:cursor-not-allowed disabled:opacity-50"
      >
        Realizar pedido por WhatsApp
      </button>
      <button id="carrito-vaciar" type="button" class="mt-2 w-full rounded-md px-5 py-2 text-sm text-muted hover:text-danger">
        Vaciar pedido
      </button>
    </footer>
  </aside>
</div>

<script>
  type Item = { id: number; nombre: string; precio: number | null; cant: number };

  const KEY = 'feghadal-pedido';
  const root = document.getElementById('carrito')!;
  const numero = root.dataset.whatsapp || '';

  const $ = (id: string) => document.getElementById(id)!;
  const panel = $('carrito-panel');
  const overlay = $('carrito-overlay');
  const itemsBox = $('carrito-items');
  const countEl = $('carrito-count');
  const totalEl = $('carrito-total');
  const notaEl = $('carrito-nota');
  const btnPedido = $('carrito-pedido') as HTMLButtonElement;

  const soles = (n: number) => `S/ ${n.toFixed(2)}`;

  const leer = (): Item[] => {
    try {
      return JSON.parse(localStorage.getItem(KEY) || '[]');
    } catch {
      return [];
    }
  };
  const guardar = (items: Item[]) => localStorage.setItem(KEY, JSON.stringify(items));

  function add(it: Omit<Item, 'cant'>) {
    const items = leer();
    const ex = items.find((x) => x.id === it.id);
    if (ex) ex.cant++;
    else items.push({ ...it, cant: 1 });
    guardar(items);
    render();
  }

  function setCant(id: number, delta: number) {
    let items = leer();
    const it = items.find((x) => x.id === id);
    if (!it) return;
    it.cant += delta;
    if (it.cant <= 0) items = items.filter((x) => x.id !== id);
    guardar(items);
    render();
  }

  function quitar(id: number) {
    guardar(leer().filter((x) => x.id !== id));
    render();
  }

  function abrir() {
    overlay.classList.remove('hidden');
    panel.classList.remove('translate-x-full');
    $('carrito-cerrar').focus();
  }
  function cerrar() {
    overlay.classList.add('hidden');
    panel.classList.add('translate-x-full');
  }

  function render() {
    const items = leer();
    const totalCant = items.reduce((s, x) => s + x.cant, 0);
    countEl.textContent = String(totalCant);
    countEl.classList.toggle('hidden', totalCant === 0);

    if (items.length === 0) {
      itemsBox.innerHTML =
        '<p class="mt-8 text-center text-muted">Tu pedido está vacío.<br>Agrega productos del catálogo.</p>';
    } else {
      itemsBox.innerHTML = items
        .map((x) => {
          const sub = x.precio != null ? soles(x.precio * x.cant) : 'A cotizar';
          return `<div class="flex items-start gap-3 border-b border-line py-3">
            <div class="flex-1">
              <p class="text-sm font-medium text-ink">${x.nombre}</p>
              <p class="text-xs text-muted">${x.precio != null ? soles(x.precio) + ' c/u' : 'Precio a cotizar'}</p>
              <div class="mt-2 inline-flex items-center rounded-md border border-line">
                <button data-dec="${x.id}" aria-label="Quitar uno" class="px-3 py-1 text-lg leading-none text-brand-700">−</button>
                <span class="min-w-[2rem] text-center text-sm">${x.cant}</span>
                <button data-inc="${x.id}" aria-label="Agregar uno" class="px-3 py-1 text-lg leading-none text-brand-700">+</button>
              </div>
            </div>
            <div class="text-right">
              <p class="text-sm font-semibold text-ink">${sub}</p>
              <button data-del="${x.id}" class="mt-1 text-xs text-muted hover:text-danger">Eliminar</button>
            </div>
          </div>`;
        })
        .join('');
    }

    const conPrecio = items.filter((x) => x.precio != null);
    const hayCotizar = items.some((x) => x.precio == null);
    const total = conPrecio.reduce((s, x) => s + (x.precio as number) * x.cant, 0);
    totalEl.textContent = items.length === 0 ? soles(0) : hayCotizar && conPrecio.length === 0 ? 'A cotizar' : soles(total);
    notaEl.classList.toggle('hidden', !hayCotizar || items.length === 0);
    btnPedido.disabled = items.length === 0;
  }

  function realizarPedido() {
    const items = leer();
    if (items.length === 0) return;
    const hayCotizar = items.some((x) => x.precio == null);
    const lineas = items.map((x) => {
      const base = `• ${x.cant} x ${x.nombre}`;
      return x.precio != null ? `${base} — ${soles(x.precio * x.cant)}` : `${base} — (a cotizar)`;
    });
    const conPrecio = items.filter((x) => x.precio != null);
    const total = conPrecio.reduce((s, x) => s + (x.precio as number) * x.cant, 0);
    const encabezado = hayCotizar
      ? 'Hola FEGHADAL, quiero solicitar una cotización para este pedido:'
      : 'Hola FEGHADAL, quiero realizar el siguiente pedido:';
    const cierre =
      conPrecio.length === 0
        ? '\n\nPor favor confírmenme los precios y la disponibilidad.'
        : hayCotizar
          ? `\n\nSubtotal (productos con precio): ${soles(total)}\nHay productos por cotizar; confírmenme el total.`
          : `\n\nTotal: ${soles(total)}`;
    const texto = `${encabezado}\n\n${lineas.join('\n')}${cierre}`;
    window.open(`https://wa.me/${numero}?text=${encodeURIComponent(texto)}`, '_blank', 'noopener');
  }

  // Eventos
  document.addEventListener('click', (e) => {
    const t = e.target as HTMLElement;
    const btn = t.closest('.agregar-pedido') as HTMLElement | null;
    if (btn) {
      add({
        id: Number(btn.dataset.id),
        nombre: btn.dataset.nombre || '',
        precio: btn.dataset.precio ? Number(btn.dataset.precio) : null,
      });
      abrir();
    }
  });

  itemsBox.addEventListener('click', (e) => {
    const t = (e.target as HTMLElement).closest('button') as HTMLElement | null;
    if (!t) return;
    if (t.dataset.inc) setCant(Number(t.dataset.inc), 1);
    else if (t.dataset.dec) setCant(Number(t.dataset.dec), -1);
    else if (t.dataset.del) quitar(Number(t.dataset.del));
  });

  $('carrito-toggle').addEventListener('click', abrir);
  $('carrito-cerrar').addEventListener('click', cerrar);
  overlay.addEventListener('click', cerrar);
  $('carrito-vaciar').addEventListener('click', () => {
    guardar([]);
    render();
  });
  btnPedido.addEventListener('click', realizarPedido);
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !overlay.classList.contains('hidden')) cerrar();
  });

  render();
</script>
