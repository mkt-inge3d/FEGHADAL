---

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 24 24"
  class={className}
  fill={isBrand ? 'currentColor' : 'none'}
  stroke={isBrand ? undefined : 'currentColor'}
  stroke-width={isBrand ? undefined : 1.5}
  stroke-linecap={isBrand ? undefined : 'round'}
  stroke-linejoin={isBrand ? undefined : 'round'}
  {...a11y}
>
  {paths.map((d) => <path d={d} />)}
</svg>
