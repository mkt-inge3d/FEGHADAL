---
/**
 * Bloque reutilizable "Servicio + materiales: solución llave en mano".
 * Propuesta de valor integral: enlaza un servicio con los productos/materiales
 * que utiliza (enlazado cruzado servicios↔productos, CLAUDE.md §4).
 * Recibe las entradas de productos ya resueltas. No se renderiza si no hay ninguna.
 */
import type { CollectionEntry } from 'astro:content';

interface Props {
  productos: CollectionEntry<'productos'>[];
  /** Texto opcional para contextualizar el servicio que provee los materiales. */
  contexto?: string;
}

const { productos, contexto } = Astro.props;
---

{
  productos.length > 0 && (
    <section
      aria-labelledby="llave-en-mano"
      class="mt-12 rounded-lg border border-accent-200 bg-accent-50 p-6 md:p-8"
    >
      <h2 id="llave-en-mano" class="text-2xl font-bold text-accent-800">
        Solución llave en mano: servicio + materiales
      </h2>
      <p class="mt-3 max-w-2xl text-ink">
        {contexto ??
          'Ejecutamos el servicio y suministramos los materiales necesarios bajo un mismo proveedor, simplificando la compra, la logística y la facturación.'}
      </p>
      <ul class="mt-6 grid gap-4 sm:grid-cols-2">
        {productos.map((producto) => (
          <li>
            <a
              href={`/productos/${producto.id}`}
              class="group flex h-full flex-col rounded-md border border-line bg-surface p-4 hover:border-accent-400"
            >
              <span class="font-semibold text-brand-700 group-hover:underline">
                {producto.data.titulo}
              </span>
              <span class="mt-1 text-sm text-muted">
                {producto.data.resumen}
              </span>
            </a>
          </li>
        ))}
      </ul>
    </section>
  )
}
