---
/**
 * Pie de página con NAP coherente (CLAUDE.md §5 SEO local) y enlazado por silo.
 * Lista servicios, sectores y productos reales desde las collections para reforzar
 * la estructura de silos y el enlazado interno.
 */
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import { site } from '../config/site';
import logo from '../assets/brand/feghadal-logo.png';

const anio = new Date().getFullYear();

const porOrden = (a: { data: { orden: number } }, b: { data: { orden: number } }) =>
  a.data.orden - b.data.orden;

const servicios = (await getCollection('servicios')).sort(porOrden);
const sectores = (await getCollection('sectores')).sort(porOrden);
const productos = (await getCollection('productos')).sort(porOrden);

const columnas = [
  { titulo: 'Servicios', base: '/servicios', items: servicios },
  { titulo: 'Sectores', base: '/sectores', items: sectores },
  { titulo: 'Productos', base: '/productos', items: productos },
];
---

<footer class="mt-16 border-t border-line bg-surface-alt">
  <div
    class="mx-auto grid max-w-[var(--spacing-content)] gap-8 px-4 py-12 sm:grid-cols-2 lg:grid-cols-5"
  >
    <div class="sm:col-span-2 lg:col-span-1">
      <Image
        src={logo}
        alt="FEGHADAL — Servicios Generales"
        width={140}
        height={140}
        class="h-16 w-auto"
      />
      <p class="mt-3 text-sm text-muted">{site.descripcion}</p>
    </div>

    {
      columnas.map((col) => (
        <nav aria-label={`Enlaces de ${col.titulo}`}>
          <h2 class="text-sm font-semibold text-ink">
            <a
              href={col.base}
              class="underline-offset-2 hover:text-brand-700 hover:underline"
            >
              {col.titulo}
            </a>
          </h2>
          <ul class="mt-3 space-y-2">
            {col.items.map((item) => (
              <li>
                <a
                  href={`${col.base}/${item.id}`}
                  class="text-sm text-muted underline-offset-2 hover:text-brand-700 hover:underline"
                >
                  {item.data.titulo}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      ))
    }

    <div>
      <h2 class="text-sm font-semibold text-ink">Contacto</h2>
      <address class="mt-3 space-y-2 text-sm text-muted not-italic">
        <p>{site.direccion.calle}, {site.direccion.ciudad}, Perú</p>
        <p>
          <a
            href={`tel:${site.telefono.replace(/\s+/g, '')}`}
            class="underline-offset-2 hover:text-brand-700 hover:underline"
          >
            {site.telefono}
          </a>
        </p>
        <p>
          <a
            href={`mailto:${site.email}`}
            class="underline-offset-2 hover:text-brand-700 hover:underline"
          >
            {site.email}
          </a>
        </p>
        <p class="pt-2 text-xs">
          Listos para el sector privado y contrataciones con el Estado peruano
          (RNP).
        </p>
      </address>
    </div>
  </div>

  <div class="border-t border-line">
    <p class="mx-auto max-w-[var(--spacing-content)] px-4 py-4 text-xs text-muted">
      © {anio} {site.nombreLegal}. Todos los derechos reservados.
    </p>
  </div>
</footer>
