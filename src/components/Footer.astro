---
/**
 * Pie de página con NAP coherente (CLAUDE.md §5 SEO local) y enlaces por silo.
 */
import { site, navPrincipal } from '../config/site';
const anio = new Date().getFullYear();
---

<footer class="mt-16 border-t border-line bg-surface-alt">
  <div
    class="mx-auto grid max-w-[var(--spacing-content)] gap-8 px-4 py-12 sm:grid-cols-2 lg:grid-cols-4"
  >
    <div>
      <p class="text-lg font-bold text-brand-700">{site.nombre}</p>
      <p class="mt-2 text-sm text-muted">{site.descripcion}</p>
    </div>

    <nav aria-label="Navegación del pie">
      <h2 class="text-sm font-semibold text-ink">Secciones</h2>
      <ul class="mt-3 space-y-2">
        {
          navPrincipal.map((item) => (
            <li>
              <a
                href={item.href}
                class="text-sm text-muted underline-offset-2 hover:text-brand-700 hover:underline"
              >
                {item.titulo}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <div>
      <h2 class="text-sm font-semibold text-ink">Contacto</h2>
      <address class="mt-3 space-y-2 text-sm text-muted not-italic">
        <p>{site.direccion.calle}, {site.direccion.ciudad}, Perú</p>
        <p>
          <a
            href={`tel:${site.telefono.replace(/\s+/g, '')}`}
            class="underline-offset-2 hover:text-brand-700 hover:underline"
          >
            {site.telefono}
          </a>
        </p>
        <p>
          <a
            href={`mailto:${site.email}`}
            class="underline-offset-2 hover:text-brand-700 hover:underline"
          >
            {site.email}
          </a>
        </p>
      </address>
    </div>

    <div>
      <h2 class="text-sm font-semibold text-ink">Confianza</h2>
      <p class="mt-3 text-sm text-muted">
        Empresa de servicios generales lista para el sector privado y para
        contrataciones con el Estado peruano.
      </p>
    </div>
  </div>

  <div class="border-t border-line">
    <p
      class="mx-auto max-w-[var(--spacing-content)] px-4 py-4 text-xs text-muted"
    >
      © {anio} {site.nombreLegal}. Todos los derechos reservados.
    </p>
  </div>
</footer>
