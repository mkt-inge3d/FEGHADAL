# Variables públicas (prefijo PUBLIC_, se incrustan en el build estático).
# Copia este archivo a `.env` y completa los valores reales.
# En Vercel: Project Settings → Environment Variables.

# Access key del formulario de cotización (https://web3forms.com — gratis).
PUBLIC_WEB3FORMS_KEY=

# Número de WhatsApp en formato internacional SIN "+", ej. 51938514148
PUBLIC_WHATSAPP_NUMERO=51938514148

# Redes sociales (opcionales). Si se dejan vacías, el icono no se muestra.
PUBLIC_FACEBOOK_URL=
PUBLIC_INSTAGRAM_URL=

# Perfil de Empresa de Google (opcional). Enlace a la ficha en Google Maps.
PUBLIC_GOOGLE_BUSINESS_URL=
