# Variables públicas (prefijo PUBLIC_, se incrustan en el build estático).
# Copia este archivo a `.env` y completa los valores reales.
# En Vercel: Project Settings → Environment Variables.

# Access key del formulario de cotización (https://web3forms.com — gratis).
PUBLIC_WEB3FORMS_KEY=

# Número de WhatsApp en formato internacional SIN "+", ej. 51999000111
PUBLIC_WHATSAPP_NUMERO=
